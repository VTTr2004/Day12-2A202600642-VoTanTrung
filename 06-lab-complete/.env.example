# Copy thanh .env.local va dien gia tri that.
# Khong commit .env.local len Git.

# App
APP_NAME=Gemini Chatbot
APP_VERSION=1.0.0
ENVIRONMENT=development

# Gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-3.1-flash-lite
TEMPERATURE=0.7
MAX_OUTPUT_TOKENS=2048

# Railway se tu cap PORT khi deploy.
# Local Docker mac dinh dung 8501.
PORT=8501
